# Godot
.godot/
*.import
# Exception: the font .import files use the "keep" importer to bundle raw
# TTF bytes into the exported PCK — they are source config, not artifacts.
!assets/fonts/raw/*.import

# Build artifacts
*.apk
*.apk.idsig
*.pck
*.zip

# iOS build output (keep Xcode project sources)
*.ipa
# Large static libraries from Godot export templates (downloaded by CI)
Trump.xcframework/
MoltenVK.xcframework/

# Screenshots
screenshots/

# Claude / Superpowers
.claude/
.superpowers/
