# Godot
.godot/
*.import
# Exception: the font .import files use the "keep" importer to bundle raw
# TTF bytes into the exported PCK — they are source config, not artifacts.
!assets/fonts/raw/*.import

# Build artifacts
*.apk
*.apk.idsig
*.pck
# Exception: Trump.pck is the iOS game data bundle and is required by
# Xcode Cloud at build time. Re-export from Godot before each TestFlight push.
!Trump.pck
*.zip

# Linux/headless server export
*.x86_64
Trump.sh

# iOS build output (keep Xcode project sources)
*.ipa
build/
Trump.xcodeproj/project.xcworkspace/xcuserdata/
Trump.xcodeproj/project.xcworkspace/xcshareddata/
.DS_Store
# Large static libraries from Godot export templates (downloaded by CI)
Trump.xcframework/
MoltenVK.xcframework/

# Screenshots
screenshots/

# Claude / Superpowers
.claude/
.superpowers/
